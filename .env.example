TAVILY_API_KEY=

# GMI Cloud mode. Best for hackathon credits and serverless Model Hub inference.
AI_PROVIDER=gmi
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
AI_MODEL=zai-org/GLM-5.2-FP8
AI_MODEL_FALLBACKS=MiniMaxAI/MiniMax-M3
AI_AGENT_DELAY_MS=1000
AI_CAPACITY_RETRIES=1
AI_CAPACITY_RETRY_DELAY_MS=5000
AI_QUOTA_RETRIES=0

# Final-demo Nemotron option:
# AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# AI_MODEL_FALLBACKS=zai-org/GLM-5.2-FP8,MiniMaxAI/MiniMax-M3

# Direct Gemini mode. Good for local testing when you have a Gemini API key.
# AI_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=
# AI_MODEL=gemini-2.5-flash-lite
# AI_MODEL_FALLBACKS=gemini-2.0-flash
# AI_AGENT_DELAY_MS=8000
# AI_CAPACITY_RETRIES=1
# AI_CAPACITY_RETRY_DELAY_MS=8000
# AI_QUOTA_RETRIES=1
# AI_QUOTA_RETRY_DELAY_MS=65000

# Alternative AI Gateway mode.
# AI_GATEWAY_API_KEY=
# AI_MODEL=openai/gpt-5.5
